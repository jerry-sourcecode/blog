---
import { render, type CollectionEntry } from 'astro:content'
import * as cheerio from 'cheerio'

import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import PostLayout from '@/layouts/BlogPost.astro'

export const prerender = true

export async function getStaticPaths() {
  const posts = sortMDByDate(await getBlogCollection())
  return posts.map((post) => ({
    params: { id: post.data?.slug ?? post.id },
    props: { post, posts }
  }))
}
/**
 * 从 HTML 字符串中提取位于 <blockquote> 或 <details class="callout"> 内部标题标签（h1~h6）的 id。
 * 使用 cheerio 进行可靠解析，支持嵌套结构和复杂 HTML。
 * @param html - 待搜索的 HTML 字符串
 * @returns 提取到的 id 值数组
 */
function extractIdsFromContainers(html: string = ''): string[] {
  const $ = cheerio.load(html)
  const ids: string[] = []

  // 选择所有 blockquote 元素，以及 class 包含 "callout" 的 details 元素
  $('blockquote, details.callout').each((_, container) => {
    // 在容器内部查找所有标题标签
    $(container)
      .find('h1, h2, h3, h4, h5, h6')
      .each((_, heading) => {
        const id = $(heading).attr('id')
        if (id !== undefined) {
          ids.push(id)
        }
      })
  })

  return ids
}

type Props = {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { post, posts } = Astro.props
let { Content, headings, remarkPluginFrontmatter } = await render(post)

const ignoreHeading = new Set(extractIdsFromContainers(post.rendered?.html))

headings = headings.filter((heading) => !ignoreHeading.has(heading.slug))
---

<PostLayout {post} {posts} {headings} {remarkPluginFrontmatter}>
  <Content />
</PostLayout>
