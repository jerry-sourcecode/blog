---
import { render, type CollectionEntry } from 'astro:content'

import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import PostLayout from '@/layouts/BlogPost.astro'

export const prerender = true

export async function getStaticPaths() {
  const posts = sortMDByDate(await getBlogCollection())
  return posts.map((post) => ({
    params: { id: post.data?.slug ?? post.id },
    props: { post, posts }
  }))
}

function extractIdsFromBlockquoteHeadings(str: string): string[] {
  const regex = /<blockquote>\s*<(h[1-6])\s+[^>]*\bid\s*=\s*(["'])([^"']*)\2[^>]*>/gi
  const ids: string[] = []
  let match: RegExpExecArray | null

  while ((match = regex.exec(str)) !== null) {
    // 捕获组 3 是 id 值
    ids.push(match[3])
  }

  return ids
}

type Props = {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { post, posts } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(post)

const ignoreHeading = extractIdsFromBlockquoteHeadings(post.rendered!.html!)
---

<PostLayout {post} {posts} {headings} {remarkPluginFrontmatter} {ignoreHeading}>
  <Content />
</PostLayout>
