---
interface Props {
  placeholder?: string;
  value?: string;
  name?: string;
  id: string;
  className?: string;
  disabled?: boolean;
  required?: boolean;
  label?: string;
}

const {
  placeholder = '',
  value = '',
  name = '',
  id = '',
  className = '',
  disabled = false,
  required = false,
  label = "",
  ...rest
} = Astro.props;
---

<div style="display: flex; width: 100%; align-items: center;">
  <label for={id} style="width: 5rex">{label}</label>
    <input
      type="text"
      {placeholder}
      {value}
      {name}
      id={id}
      class={`waline-input ${className}`}
      {disabled}
      {required}
      {...rest}
    />
</div>

<style>
  .waline-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    font-size: 1rem;
    line-height: 1.5;
    transition: border-color 0.2s ease-in-out;
    //box-sizing: border-box;
  }

  .waline-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
  }

  .waline-input:disabled {
    background-color: #f9fafb;
    cursor: not-allowed;
    opacity: 0.8;
  }
</style>