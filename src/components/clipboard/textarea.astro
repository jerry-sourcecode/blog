---
interface Props {
  placeholder?: string;
  value?: string;
  name?: string;
  id?: string;
  className?: string;
  disabled?: boolean;
  required?: boolean;
  rows?: number;
  cols?: number;
}

const {
  placeholder = '',
  value = '',
  name = '',
  id = '',
  className = '',
  disabled = false,
  required = false,
  rows = 4,
  cols = 100,
  ...rest
} = Astro.props;
---

<textarea
  {placeholder}
  {value}
  {name}
  {id}
  class={`waline-textarea ${className}`}
  {disabled}
  {required}
  {rows}
  {cols}
  {...rest}
></textarea>

<style>
  .waline-textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    font-size: 1rem;
    line-height: 1.5;
    transition: border-color 0.2s ease-in-out;
    resize: vertical;
    box-sizing: border-box;
    min-height: calc(1rem * 1.5 * 4); /* 匹配默认 rows 高度 */
  }

  .waline-textarea:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
  }

  .waline-textarea:disabled {
    background-color: #f9fafb;
    cursor: not-allowed;
    opacity: 0.8;
  }
</style>